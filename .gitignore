# Claude Code session transcripts (date-stamped exports — kept locally, never pushed).
# Pattern is scoped to the YYYY-MM-DD-HHMMSS export name so it can't swallow
# requirements.txt or any other real .txt the project might add later.
20[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*.txt

# Local editor / agent settings (Unity/Zotero/etc. tooling — not part of this project)
.claude/

# macOS cruft
.DS_Store
**/.DS_Store

# Python bytecode
__pycache__/
*.py[cod]
